{
  "format_version": "1.21.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "geyser_mc:custom/vehicles/tank_legend_sand",
      "materials": {
        "default": "entity_alphatest",
        "enchanted": "entity_alphatest_glint"
      },
      "textures": {
        "enchanted": "textures/misc/enchanted_item_glint",
        "default": "textures/custom/cars/tank_legend_sand"
      },
      "geometry": {
        "default": "geometry.geyser_mc.custom_vehicles_tank_legend_black"
      },
      "animations": {
        "third_person": "animation.geyser_mc.custom_vehicles_tank_legend_sand.hold_third_person",
        "first_person": "animation.geyser_mc.custom_vehicles_tank_legend_sand.hold_first_person",
        "head": "animation.geyser_mc.custom_vehicles_tank_legend_sand.head"
      },
      "scripts": {
        "animate": [
          {
            "first_person": "context.is_first_person == 1.0 && (context.item_slot == 'main_hand' || context.item_slot == 'off_hand')"
          },
          {
            "third_person": "context.is_first_person == 0.0 && (context.item_slot == 'main_hand' || context.item_slot == 'off_hand')"
          },
          {
            "head": "context.is_first_person == 0.0 && context.item_slot == 'head'"
          }
        ]
      },
      "render_controllers": [
        "controller.render.item_default"
      ]
    }
  }
}